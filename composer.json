		],
		"post-update-cmd": [
			"bash -c \"[ -f vendor/mikey179/vfsstream/src/main/php/org/bovigo/vfs/vfsStream.php ] && sed -i s/name{0}/name[0]/ vendor/mikey179/vfsstream/src/main/php/org/bovigo/vfs/vfsStream.php || true\""
		]
